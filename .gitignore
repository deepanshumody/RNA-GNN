# Byte-compiled / optimized / cache
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# Tooling caches
.pytest_cache/
.ruff_cache/

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/

# Editor / OS cruft
.DS_Store
.idea/
.vscode/
*.swp

# Claude Code local session state
.claude/

# Training / inference artifacts (regenerated by the scripts)
save*/
saved_tensors/
*.pt
!best_model.pth          # keep the released checkpoint
1fuf_merged.pdb          # generated by the demo app at runtime
[0-9]*morepos.png        # per-epoch PR curves from GNN-DTI training
/preds_*.csv             # per-run predictions (root); data/preds_*.csv is kept
/roc_curve.png           # ROC curve written by the training scripts
